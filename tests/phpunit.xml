<?xml version="1.0" encoding="UTF-8"?>
<phpunit
	bootstrap="bootstrap-unit.php"
	colors="true"
	cacheDirectory=".phpunit.cache"
	failOnRisky="true"
	failOnWarning="true">
	<testsuites>
		<testsuite name="unit">
			<directory suffix="Test.php">./Unit</directory>
		</testsuite>
		<testsuite name="integration">
			<directory suffix="Test.php">./Integration</directory>
		</testsuite>
	</testsuites>
</phpunit>
