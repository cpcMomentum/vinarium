    "@nextcloud/vue": "^9.5.0",
    "cropperjs": "^1.6.2",
    "linkifyjs": "^4.1.3",
    "pinia": "^2.3.1",
    "vue": "^3.5.13",
    "vue-cropperjs": "^5.0.0",
    "vue-material-design-icons": "^5.3.1",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@nextcloud/eslint-config": "^6.1.0",
    "@vitejs/plugin-vue": "^6.0.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.7.0",
    "happy-dom": "^20.9.0",
    "sass": "^1.70.0",
