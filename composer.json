{
  "name": "cpcmomentum/vinarium",
  "description": "Private Weinkeller-Verwaltung als Nextcloud-App",
  "license": "AGPL-3.0-or-later",
  "type": "project",
  "require": {
    "php": ">=8.2"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5",
    "nextcloud/ocp": "^32.0 || ^33.0 || ^34.0",
    "doctrine/dbal": "^4.0"
  },
  "autoload": {
    "psr-4": {
      "OCA\\Vinarium\\": "lib/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "OCA\\Vinarium\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit -c tests/phpunit.xml",
    "test:unit": "phpunit -c tests/phpunit.xml"
  },
  "config": {
    "sort-packages": true,
    "optimize-autoloader": true
  }
}
